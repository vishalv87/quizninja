# QuizNinja API Configuration
# Copy this file to .env and update with your actual values

# Server Configuration
PORT=8080
GIN_MODE=debug

# CORS Configuration (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GLOBAL=100
RATE_LIMIT_AUTH=5
RATE_LIMIT_WRITE=20
RATE_LIMIT_PER_USER=60

# Database Configuration (Traditional PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=quizninja

# Supabase Configuration
# Set USE_SUPABASE=true to use Supabase instead of traditional PostgreSQL
USE_SUPABASE=true

# Supabase API Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_key_here

# Supabase Database Configuration
# Get these values from your Supabase project settings > Database
SUPABASE_DB_HOST=your_supabase_db_host_here
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your_supabase_db_password_here
SUPABASE_DB_NAME=postgres

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GLOBAL=100
RATE_LIMIT_AUTH=5
RATE_LIMIT_WRITE=20
RATE_LIMIT_PER_USER=60

# Request Size Limiting (values in MB)
REQUEST_SIZE_LIMIT_ENABLED=true
REQUEST_SIZE_DEFAULT=10
REQUEST_SIZE_AUTH=1
REQUEST_SIZE_WRITE=5

# Mock Auth (for testing only - NEVER enable in production)
USE_MOCK_AUTH=false

# How to get Supabase credentials:
# 1. Go to https://supabase.com/dashboard
# 2. Select your project
# 3. Go to Settings > API to get SUPABASE_URL and SUPABASE_ANON_KEY
# 4. Go to Settings > Database to get database connection details
# 5. Use the "Connection string" but extract individual components above

# Migration Notes:
# - When USE_SUPABASE=true, all 36 existing migration files will run on Supabase
# - This includes all seed data and custom functions
# - The migration system works identically on both PostgreSQL and Supabase
# - To rollback, simply set USE_SUPABASE=false and restart the application
